{
  "name": "mortic",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "mortic": "./dist/node/cli/main.js"
  },
  "scripts": {
    "dev": "tsx src/cli/main.ts",
    "build": "tsc -p tsconfig.node.json && vite build",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "test": "npm run build && node scripts/check_voice_pipeline.mjs && node scripts/check_spark_context.mjs && node scripts/check_input_control.mjs && node scripts/check_project_storage.mjs && node scripts/check_canonical_state_skill.mjs",
    "start": "node dist/node/cli/main.js",
    "eval:mortic-voice:generate": "node evals/mortic-voice-output/run.mjs generate",
    "eval:mortic-voice:score": "node evals/mortic-voice-output/run.mjs score",
    "eval:mortic-voice:subagents": "node evals/mortic-voice-output/run.mjs subagent-prompts",
    "eval:models:telemetry": "node evals/model-runtime-telemetry/run.mjs",
    "check:spark-context": "node scripts/check_spark_context.mjs",
    "probe:tts": "node scripts/tts_ws_probe.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "fastify": "^5.6.2",
    "livekit-client": "^2.18.8",
    "livekit-server-sdk": "^2.15.2",
    "open": "^10.2.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "vite": "^7.2.6",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
