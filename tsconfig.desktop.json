{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist/desktop",
    "rootDir": "src",
    "lib": ["ES2022"],
    "types": ["node", "electron"],
    "noEmit": false
  },
  "include": ["src/desktop/**/*.ts", "src/cli/runtime.ts", "src/server/**/*.ts", "src/shared/**/*.ts"],
  "exclude": ["src/server/codexAppServerProtocol/**/*.ts"]
}
