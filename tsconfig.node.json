{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist/node",
    "rootDir": "src",
    "lib": ["ES2022"],
    "types": ["node"],
    "noEmit": false
  },
  "include": ["src/cli/**/*.ts", "src/server/**/*.ts", "src/shared/**/*.ts"],
  "exclude": ["src/server/codexAppServerProtocol/**/*.ts"]
}
